# Environment Variables Template
# Copy this to .env.local and fill in the values

# Neon Database URL (direct connection string)
DATABASE_URL=postgres://...

# API Key for Vercel Functions and Frontend
# Must be identical in both VERCEL Environment Variables and local .env
API_KEY=your_secret_api_key_here
VITE_API_KEY=your_secret_api_key_here

# Github Token (if needed for any scripts)
GITHUB_TOKEN=...
