# Plantilla de Variables de Entorno — app-carrera
# Copia este archivo a .env.local y completa los valores.
#
# ⚠️  SEGURIDAD: Las variables con prefijo VITE_ se incluyen en el bundle
#     JavaScript público y son visibles para cualquier usuario con DevTools.
#     API_KEY NO debe tener prefijo VITE_. El frontend llama a /api/proxy/*
#     que inyecta la clave en el servidor, nunca en el cliente.

# ── Adapter de persistencia ─────────────────────────────────────────────────
# 'api' = Neon/Vercel (producción) | 'localStorage' = modo offline/dev
# Si no se define, el fallback es 'api'.
# ── Observabilidad (Sentry) ─────────────────────────────────────────────────
# DSN público de Sentry para captura de errores en producción.
# Obtener en: Sentry Dashboard → Settings → Projects → tu proyecto → Client Keys (DSN).
# Sin este valor Sentry queda desactivado silenciosamente.
# Prefijo VITE_ es correcto: el DSN es público por diseño.
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

VITE_ADAPTER=api

# ── Base de datos ───────────────────────────────────────────────────────────
# Cadena de conexión Neon PostgreSQL (solo usada por funciones serverless).
DATABASE_URL=postgres://usuario:password@host/dbname?sslmode=require

# ── API Key del servidor ─────────────────────────────────────────────────────
# Usada EXCLUSIVAMENTE por las Vercel Serverless Functions (api/*.js).
# NO añadir prefijo VITE_ — debe permanecer fuera del bundle del cliente.
API_KEY=tu_clave_secreta_aqui

# ── CORS ────────────────────────────────────────────────────────────────────
# Dominio permitido en Access-Control-Allow-Origin del proxy BFF.
# Ejemplo producción: https://appcarrera.vercel.app
ALLOWED_ORIGIN=https://appcarrera.vercel.app

# ── Vercel Blob ──────────────────────────────────────────────────────────────
# Token de lectura/escritura de Vercel Blob.
# Requerido por api/docs/[patId].js y api/images/index.js para subida de
# documentos e imágenes. Sin este valor, ambas APIs fallan con error 500.
# Obtener en: Vercel Dashboard → Storage → Blob → tu store → Tokens.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxx

# ── Proxy de Vite en desarrollo (ARQ-05) ────────────────────────────────────
# Enruta /api en desarrollo al backend real. Deja vacío para modo offline.
# ⚠️  Con este valor activo, las peticiones locales modifican producción.
VITE_API_PROXY_TARGET=https://appcarrera.vercel.app

# ── GitHub (opcional) ───────────────────────────────────────────────────────
GITHUB_TOKEN=tu_token_de_github_aqui
