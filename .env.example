# Plantilla de Variables de Entorno
# Copia este archivo a .env.local y completa los valores

# URL de la base de datos Neon (cadena de conexión directa)
DATABASE_URL=postgres://usuario:password@host/dbname?sslmode=require

# API Key para Funciones de Vercel y Frontend
# Debe ser idéntica tanto en las variables de entorno de Vercel como en el .env local
API_KEY=tu_clave_secreta_aqui
VITE_API_KEY=tu_clave_secreta_aqui

# Token de Github (si es necesario para algún script)
GITHUB_TOKEN=tu_token_de_github_aqui
